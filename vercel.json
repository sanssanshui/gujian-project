{
  "version": 2,
  "functions": {
    "server.js": {
      "runtime": "@vercel/node@3"
    }
  },
  "routes": [
   
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    
    {
      "src": "/(.*\\.(html|css|js|png|jpg|jpeg|gif|svg|ico|webp|woff|woff2|ttf|eot))$",
      "dest": "/public/$1"
    },
    
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}